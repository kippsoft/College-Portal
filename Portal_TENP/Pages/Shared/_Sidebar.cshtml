
@using Microsoft.AspNetCore.Http

@{
    var userType = Context.Session.GetString("UserType");
    var roles = Context.Session.GetString("Roles") ?? "";
}

<aside class="main-sidebar sidebar-dark-primary elevation-4">

    <a href="/" class="brand-link">
        <span class="brand-text font-weight-light">E-College Portal</span>
    </a>

    <div class="sidebar">

        <!-- User Panel -->

        <div class="user-panel mt-3 pb-3 mb-3 d-flex">
            <div class="info">

                @if (userType == "Trainee")
                {
                    <a href="#" class="d-block">
                        @Context.Session.GetString("Name")
                    </a>
                }
                else
                {
                    <a href="#" class="d-block">
                        @Context.Session.GetString("StaffName")
                    </a>
                }

            </div>
        </div>

        <nav class="mt-2">

            <ul class="nav nav-pills nav-sidebar flex-column"
                data-widget="treeview"
                role="menu">

                <!-- TRAINEE MENU -->
                @if (userType == "Trainee")
                {

                    <li class="nav-item">
                        <a href="/Trainee/Dashboard" class="nav-link">
                            <i class="nav-icon fas fa-home"></i>
                            <p>Dashboard</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/Trainee/BioData" class="nav-link">
                            <i class="nav-icon fas fa-user"></i>
                            <p>Bio Data</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/Trainee/FeesStructure" class="nav-link">
                            <i class="nav-icon fas fa-money-bill"></i>
                            <p>Fees Structure</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/Trainee/FeesStatement" class="nav-link">
                            <i class="nav-icon fas fa-file-invoice"></i>
                            <p>Fees Statement</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/Trainee/RegisterExams" class="nav-link">
                            <i class="nav-icon fas fa-edit"></i>
                            <p>Register Exams</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/Trainee/ExamStatus" class="nav-link">
                            <i class="nav-icon fas fa-check"></i>
                            <p>Exam Registration Status</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/Trainee/UploadPOE" class="nav-link">
                            <i class="nav-icon fas fa-upload"></i>
                            <p>Upload POE</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/Trainee/Results" class="nav-link">
                            <i class="nav-icon fas fa-chart-bar"></i>
                            <p>Results</p>
                        </a>
                    </li>

                }


                <!-- TRAINER MENU -->
                @if (roles.Contains("1"))
                {

                    <li class="nav-item">
                        <a href="/Trainer/Dashboard" class="nav-link">
                            <i class="nav-icon fas fa-chalkboard-teacher"></i>
                            <p>Trainer Dashboard</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/Trainer/MyUnits" class="nav-link">
                            <i class="nav-icon fas fa-book"></i>
                            <p>Assigned Units</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/Trainer/ViewPOE" class="nav-link">
                            <i class="nav-icon fas fa-folder-open"></i>
                            <p>View Trainee POEs</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/Trainer/UploadMarks" class="nav-link">
                            <i class="nav-icon fas fa-pen"></i>
                            <p>Upload Marks</p>
                        </a>
                    </li>

                }


                <!-- FINANCE MENU -->
                @if (roles.Contains("4"))
                {

                    <li class="nav-item">
                        <a href="/Finance/Dashboard" class="nav-link">
                            <i class="nav-icon fas fa-coins"></i>
                            <p>Finance Dashboard</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/Finance/StudentStatements" class="nav-link">
                            <i class="nav-icon fas fa-file-invoice"></i>
                            <p>Student Statements</p>
                        </a>
                    </li>

                }


                <!-- EXAMS MENU -->
                @if (roles.Contains("5"))
                {

                    <li class="nav-item">
                        <a href="/Exams/Dashboard" class="nav-link">
                            <i class="nav-icon fas fa-graduation-cap"></i>
                            <p>Exams Dashboard</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/Exams/Registrations" class="nav-link">
                            <i class="nav-icon fas fa-list"></i>
                            <p>Exam Registrations</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/Exams/Results" class="nav-link">
                            <i class="nav-icon fas fa-chart-line"></i>
                            <p>Manage Results</p>
                        </a>
                    </li>

                }


                <!-- ADMIN MENU -->
                @if (roles.Contains("0"))
                {

                    <li class="nav-item">
                        <a href="/Admin/Dashboard" class="nav-link">
                            <i class="nav-icon fas fa-cogs"></i>
                            <p>Administration</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/Admin/Staff" class="nav-link">
                            <i class="nav-icon fas fa-users"></i>
                            <p>Staff Management</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/Admin/Trainees" class="nav-link">
                            <i class="nav-icon fas fa-user-graduate"></i>
                            <p>Trainees</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/Admin/Units" class="nav-link">
                            <i class="nav-icon fas fa-book-open"></i>
                            <p>Units</p>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/Admin/TrainerAllocation" class="nav-link">
                            <i class="nav-icon fas fa-tasks"></i>
                            <p>Trainer Allocation</p>
                        </a>
                    </li>

                }

                <!-- LOGOUT -->

                <li class="nav-item">
                    <a href="/Account/Logout" class="nav-link">
                        <i class="nav-icon fas fa-sign-out-alt"></i>
                        <p>Logout</p>
                    </a>
                </li>

            </ul>

        </nav>

    </div>

</aside>